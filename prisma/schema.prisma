generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String            @id @default(cuid())
  name                    String?
  email                   String            @unique
  emailVerified           DateTime?
  image                   String?
  password                String?
  phoneNumber             String?
  role                    String            @default("CLIENT")
  isActive                Boolean           @default(true)
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  verificationToken       String?           @unique
  verificationTokenExpiry DateTime?
  resetToken              String?           @unique
  resetTokenExpiry        DateTime?
  bannedAt                DateTime?
  bannedReason            String?
  accounts                Account[]
  notifications           Notification[]
  orders                  Order[]
  quotations              Quotation[]
  sessions                Session[]
  assignedRequests        SourcingRequest[] @relation("AgentRequests")
  sourcingRequests        SourcingRequest[] @relation("ClientRequests")
}

model Notification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  link      String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SourcingRequest {
  id                 String      @id @default(cuid())
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  clientId           String
  productName        String
  description        String?
  quantity           Int
  targetPrice        Float?
  destinationCountry String?
  serviceType        String      @default("FULL_SOURCING")
  referenceImages    String?
  status             String      @default("DRAFT")
  notes              String?
  assignedAgentId    String?
  orders             Order[]
  quotations         Quotation[]
  agent              User?       @relation("AgentRequests", fields: [assignedAgentId], references: [id])
  client             User        @relation("ClientRequests", fields: [clientId], references: [id])
}

model Quotation {
  id                   String          @id @default(cuid())
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  requestId            String
  agentId              String
  unitPrice            Float
  totalPrice           Float
  supplierLocation     String?
  estimatedLeadTime    Int?
  shippingCostEstimate Float?
  notes                String?
  status               String          @default("PENDING")
  version              Int             @default(1)
  revisionNote         String?
  serviceFee           Float?
  orders               Order[]
  agent                User            @relation(fields: [agentId], references: [id])
  request              SourcingRequest @relation(fields: [requestId], references: [id])
}

model RoleChangeLog {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  userId      String
  userEmail   String
  userName    String?
  changedById String
  adminEmail  String
  fromRole    String
  toRole      String
}

model Order {
  id                      String          @id @default(cuid())
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  requestId               String
  quotationId             String
  clientId                String
  status                  String          @default("CONFIRMED")
  shippingMark            String?
  trackingNumber          String?
  carrier                 String?
  estimatedDelivery       DateTime?
  invoiceUrl              String?
  paymentConfirmedAt      DateTime?
  paymentReceiptUrl       String?
  paymentRejectedReason   String?
  paymentSubmittedAt      DateTime?
  shippingMarkCartons     Int?
  shippingMarkDimensions  String?
  shippingMarkGrossWeight String?
  shippingMarkNetWeight   String?
  shippingMarkNotes       String?
  shippingMarkRef         String?
  shippingMarkSentAt      DateTime?
  client                  User            @relation(fields: [clientId], references: [id])
  quotation               Quotation       @relation(fields: [quotationId], references: [id])
  request                 SourcingRequest @relation(fields: [requestId], references: [id])
}
