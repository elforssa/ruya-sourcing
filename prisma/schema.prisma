generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  role           String    @default("CLIENT")
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  sourcingRequests SourcingRequest[] @relation("ClientRequests")
  assignedRequests SourcingRequest[] @relation("AgentRequests")
  quotations      Quotation[]
  orders          Order[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SourcingRequest {
  id                 String    @id @default(cuid())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  clientId           String
  client             User      @relation("ClientRequests", fields: [clientId], references: [id])

  productName        String
  description        String?
  quantity           Int
  targetPrice        Float?
  destinationCountry String?
  serviceType        String    @default("FULL_SOURCING")
  referenceImages    String?
  status             String    @default("DRAFT")
  notes              String?

  assignedAgentId    String?
  agent              User?     @relation("AgentRequests", fields: [assignedAgentId], references: [id])

  quotations         Quotation[]
  orders             Order[]
}

model Quotation {
  id                   String          @id @default(cuid())
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  requestId            String
  request              SourcingRequest @relation(fields: [requestId], references: [id])
  agentId              String
  agent                User            @relation(fields: [agentId], references: [id])

  unitPrice            Float
  totalPrice           Float
  supplierName         String?
  supplierLocation     String?
  estimatedLeadTime    Int?
  shippingCostEstimate Float?
  notes                String?
  revisionNote         String?
  status               String          @default("PENDING")
  version              Int             @default(1)

  orders               Order[]
}

model Order {
  id             String          @id @default(cuid())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  requestId      String
  request        SourcingRequest @relation(fields: [requestId], references: [id])
  quotationId    String
  quotation      Quotation       @relation(fields: [quotationId], references: [id])
  clientId       String
  client         User            @relation(fields: [clientId], references: [id])

  status             String    @default("CONFIRMED")
  shippingMark       String?
  trackingNumber     String?
  carrier            String?
  estimatedDelivery  DateTime?
}
