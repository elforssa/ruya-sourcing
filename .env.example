# =============================================================================
# RUYA — Sourcing Platform · Environment Variables
# Copy this file to .env.local for local development
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# Recommended providers: Neon (neon.tech), Supabase, Railway
#
# For Neon:     postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/ruya?sslmode=require
# For Supabase: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host:5432/ruya?schema=public"

# Used by Prisma for direct connections (required for Neon pooled connections)
# If not using connection pooling, set this to the same value as DATABASE_URL
DIRECT_URL="postgresql://user:password@host:5432/ruya?schema=public"

# -----------------------------------------------------------------------------
# NEXTAUTH
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET="replace-with-output-of-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
# In production set NEXTAUTH_URL to your Vercel deployment URL:
# NEXTAUTH_URL="https://your-app.vercel.app"

# -----------------------------------------------------------------------------
# EMAIL (Resend - resend.com)
# Get your API key from: https://resend.com/api-keys
# Free tier: 3,000 emails/month, 100/day
#
# EMAIL_FROM must be a verified sender on your Resend account.
# Local development:
# - You can use: RUYA Platform <onboarding@resend.dev>
# - This usually only delivers to the email address you signed up with on Resend
# - If DEV_EMAIL_TO is set below, all recipients will be overridden to that address
# Production:
# - Use your verified domain sender, for example:
#   Ruya Services <noreply@mail.ruya.services>
# - Do not set DEV_EMAIL_TO in production
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_your_api_key_here"
EMAIL_FROM="Ruya Services <noreply@mail.ruya.services>"

# Email address that receives internal admin alerts on every order status change
ADMIN_EMAIL="admin@yourdomain.com"

# Dev only: override ALL email recipients to this address (Resend free tier workaround)
# When set, every email goes to this address instead of the real user/admin recipient
# Do not set this in production
# DEV_EMAIL_TO="you@gmail.com"

# ------------------------------------------------------------------------------
# RATE LIMITING (Upstash Redis) — strongly recommended in production
# Without this, rate limits reset on every Vercel cold start.
# Get credentials at: https://console.upstash.com (free tier available)
# ------------------------------------------------------------------------------
# UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-token"
